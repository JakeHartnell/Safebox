# safebox env file — copy to ~/.config/safebox/.env and chmod 600.
#
# Variables exported here are loaded by `safebox` before the container starts
# and forwarded into every harness (claude, codex, pi). One file covers all
# three — Docker is the isolation boundary, the env file is just credential
# plumbing.
#
#   mkdir -p ~/.config/safebox
#   cp .env.example ~/.config/safebox/.env
#   chmod 600 ~/.config/safebox/.env
#   $EDITOR ~/.config/safebox/.env
#
# Override the directory with SAFEBOX_CONFIG_DIR=/some/other/dir if you keep
# secrets elsewhere (e.g. under `pass`, `gpg`, or a per-repo location).
#
# Any provider API keys already exported in your host shell are also forwarded
# automatically — this file is for keys you don't want to put in your shell rc.

# --- GitHub credentials -------------------------------------------------------
# Forwarded into the container; `gh` picks GH_TOKEN/GITHUB_TOKEN up automatically
# and entrypoint.sh wires `git` to use them for HTTPS pushes.
# Use a fine-scoped PAT (or a GitHub App installation token) limited to the
# repos the agent should touch — typically `repo` + `workflow` is enough.
GH_USER=your-agent-username
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Git identity override (optional) ----------------------------------------
# By default safebox reads `git config --global user.{name,email}` from the
# host. Uncomment to override the commit author for runs launched this way.
# GIT_AUTHOR_NAME="Agent Name"
# GIT_AUTHOR_EMAIL="agent@example.com"

# --- LLM provider API keys (optional) ----------------------------------------
# Claude and Codex normally authenticate via their own login flows (`claude
# /login`, `codex login`) and persist auth in the bind-mounted ~/.claude /
# ~/.codex dirs. Pi expects API keys directly. Set whichever keys you want
# forwarded to whatever harness; uncomment as needed.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
