# SafeClaude env file — copy to ~/.config/safe-claude/.env and chmod 600.
#
# Any variables exported here are loaded by safe-claude.sh before the container
# starts. Use it for credentials and other host-side env you want forwarded.
#
#   mkdir -p ~/.config/safe-claude
#   cp .env.example ~/.config/safe-claude/.env
#   chmod 600 ~/.config/safe-claude/.env
#   $EDITOR ~/.config/safe-claude/.env
#
# Override the path with SAFE_CLAUDE_ENV=/some/other/file if you keep secrets
# elsewhere (e.g. under `pass`, `gpg`, or a per-repo location).

# --- GitHub credentials -------------------------------------------------------
# Forwarded into the container; `gh` picks GH_TOKEN/GITHUB_TOKEN up automatically
# and entrypoint.sh wires `git` to use them for HTTPS pushes.
# Use a fine-scoped PAT (or a GitHub App installation token) limited to the
# repos the agent should touch — typically `repo` + `workflow` is enough.
GH_USER=your-agent-username
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Git identity override (optional) ----------------------------------------
# By default safe-claude reads `git config --global user.{name,email}` from the
# host. Uncomment to override the commit author for runs launched this way.
# GIT_AUTHOR_NAME="Agent Name"
# GIT_AUTHOR_EMAIL="agent@example.com"
